# ============================================
# NOVA STAR 环境变量模板
# 复制为 .env.local 并填入实际值
# ============================================

# === 应用基础配置 ===
# 客户端标识（详见 [[01-产品PRD#6.17 客户定制策略]]）
# 可选值：default | lumina | <新客户目录名>
NEXT_PUBLIC_CLIENT_ID=default

# 站点 URL（用于 OG image 绝对路径、canonical 等）
# 生产：https://nova-star.app
# 预览：https://staging.nova-star.app
# 开发：http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 构建模式
NODE_ENV=development

# === 构建配置 ===
# 是否启用 bundle analyzer（产出 .next/analyze/）
ANALYZE=false

# 是否构建 standalone（Docker 部署用）
BUILD_STANDALONE=false

# === 安全配置 ===
# CSP 调试：true 时用 Report-Only 模式（不阻断，只上报）
# 生产环境建议设为 false（正式启用 CSP）
NEXT_PUBLIC_CSP_REPORT_ONLY=false

# === 监控与埋点（可选） ===
# 错误监控（Sentry）- 留空则不启用
# NEXT_PUBLIC_SENTRY_DSN=

# 埋点（自托管 Umami）
NEXT_PUBLIC_ANALYTICS_URL=
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# === PWA 配置 ===
# Service Worker 是否启用（默认 true）
# 仅在特殊调试场景设为 false
NEXT_PUBLIC_SW_ENABLED=true

# === 部署平台相关 ===
# Vercel: 自动注入
# Netlify: 自动注入
# 自托管: 需配置
PORT=3000
HOSTNAME=0.0.0.0