{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "react/no-unescaped-entities": "off",
    "react-hooks/exhaustive-deps": "warn",
    "prefer-const": "warn",
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }],
    "no-unused-vars": "off"
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "out/",
    "public/sw.js",
    "public/workbox-*.js",
    "next-env.d.ts"
  ]
}
